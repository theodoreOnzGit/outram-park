% =============================================================================
% beamerthememidcenturymodern.sty
% A mid-century modern Beamer template. Requires LuaLaTeX.
%
% COLOUR THEMES
%
%   Two built-in themes: DeepBlue (default) and Kraft.
%   Select in your preamble before \begin{document}:
%
%     \usepackage{beamerthememidcenturymodern}
%     \mcmTheme{Kraft}
%
% FONTS
%
%   Body: Lato (fallback: Helvetica).
%   Titles: TeX Gyre Heros (fallback: default sans).
%
%   Override in your preamble after loading the template:
%     \setsansfont{Font Name}
%     \renewfontfamily\mcmTitleFont{Font Name}
%
% =============================================================================
\ProvidesPackage{beamerthememidcenturymodern}[2025/01/01 Mid-Century Modern Beamer Template]

\setbeamersize{text margin left=2em, text margin right=2em}

\RequirePackage{calc}
\RequirePackage{tikz}
\RequirePackage{etoolbox}
\RequirePackage{fontspec}
\RequirePackage{hyperref}
\RequirePackage{ragged2e}
\defaultfontfeatures{Ligatures=TeX}

\setbeamertemplate{frametitle continuation}{}

% ---------------------------------------------------------------------------
% FONTS
% ---------------------------------------------------------------------------
\IfFontExistsTF{Lato}{%
  \setsansfont{Lato}%
}{%
  \IfFontExistsTF{Helvetica}{\setsansfont{Helvetica}}{}%
}
\renewcommand{\familydefault}{\sfdefault}

\IfFontExistsTF{TeX Gyre Heros}{%
  \newfontfamily\mcmTitleFont{TeX Gyre Heros}%
}{%
  \let\mcmTitleFont\sffamily
}

% Uppercase titles (default on). Disable: \mcmTitleUppercasefalse
\newif\ifmcmTitleUppercase
\mcmTitleUppercasetrue

% Extra word spacing on the title page (default 0.5em)
\newlength{\mcmTitleWordSpacing}
\setlength{\mcmTitleWordSpacing}{0.5em}

% Helper: apply title font + optional uppercase
\newcommand{\mcmTitleFormat}[1]{%
  {\mcmTitleFont
   \ifmcmTitleUppercase\MakeUppercase{#1}\else#1\fi}%
}

\mode<presentation>{
  \usetheme{default}
  \usefonttheme{professionalfonts}
  \setbeamertemplate{navigation symbols}{}
}

