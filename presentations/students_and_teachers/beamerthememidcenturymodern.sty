% ---------------------------------------------------------------------------
% SEMANTIC COLOUR ALIASES — set by \mcmTheme
% ---------------------------------------------------------------------------
\colorlet{mcmPrimary}{mcmDeepBlue}
\colorlet{mcmPrimaryDark}{mcmDarkBlue}
\colorlet{mcmPrimaryFg}{mcmLightGray}
\colorlet{mcmPrimaryAccent}{mcmLightBlue}
\colorlet{mcmPrimaryMuted}{mcmDeepBlue!10}
\colorlet{mcmPip}{mcmDeepBlue}
\colorlet{mcmBlockTitleFg}{mcmDeepBlue}
\colorlet{mcmScanLine}{mcmDeepBlue!55}
\colorlet{mcmAlert}{mcmPink}
\colorlet{mcmAlertBg}{mcmLightPink}
\colorlet{mcmExample}{mcmMintTitle}
\colorlet{mcmExampleBg}{mcmMintBlock}

% ---------------------------------------------------------------------------
% THEME COMMAND
% ---------------------------------------------------------------------------
\newcommand{\mcmTheme}[1]{%
  \def\mcm@theme{#1}%
  \ifstrequal{#1}{Kraft}{%
    \colorlet{mcmPrimary}{mcmTerracotta}%
    \colorlet{mcmPrimaryDark}{mcmTerracotta!80!black}%
    \colorlet{mcmPrimaryFg}{mcmKraft}%
    \colorlet{mcmPrimaryAccent}{mcmKraftLight}%
    \colorlet{mcmPrimaryMuted}{mcmTerracotta!10}%
    \colorlet{mcmPip}{mcmTerracotta}%
    \colorlet{mcmBlockTitleFg}{mcmTerracotta}%
    \colorlet{mcmScanLine}{mcmTerracotta!55}%
    \colorlet{mcmAlert}{mcmAmber}%
    \colorlet{mcmAlertBg}{mcmLightAmber}%
    \colorlet{mcmExample}{mcmSage}%
    \colorlet{mcmExampleBg}{mcmLightSage}%
    \mcm@applytheme
  }{%
    \colorlet{mcmPrimary}{mcmDeepBlue}%
    \colorlet{mcmPrimaryDark}{mcmDarkBlue}%
    \colorlet{mcmPrimaryFg}{mcmLightGray}%
    \colorlet{mcmPrimaryAccent}{mcmLightBlue}%
    \colorlet{mcmPrimaryMuted}{mcmDeepBlue!10}%
    \colorlet{mcmPip}{mcmDeepBlue}%
    \colorlet{mcmBlockTitleFg}{mcmDeepBlue}%
    \colorlet{mcmScanLine}{mcmDeepBlue!55}%
    \colorlet{mcmAlert}{mcmPink}%
    \colorlet{mcmAlertBg}{mcmLightPink}%
    \colorlet{mcmExample}{mcmMintTitle}%
    \colorlet{mcmExampleBg}{mcmMintBlock}%
    \mcm@applytheme
  }%
}

\newcommand{\mcm@applytheme}{%
  \setbeamercolor{frametitle}{fg=mcmPrimaryFg, bg=mcmPrimary}%
  \setbeamercolor{block title}{fg=mcmBlockTitleFg, bg=mcmBg}%
  \setbeamercolor{block title alerted}{fg=mcmAlert, bg=mcmAlertBg}%
  \setbeamercolor{block body alerted}{fg=mcmBlack, bg=mcmAlertBg}%
  \setbeamercolor{block title example}{fg=mcmExample, bg=mcmExampleBg}%
  \setbeamercolor{block body example}{fg=mcmBlack, bg=mcmExampleBg}%
  \setbeamercolor{alerted text}{fg=mcmAlert}%
  \setbeamercolor{example text}{fg=mcmExample}%
  \setbeamercolor{section in toc}{fg=mcmPip}%
  \setbeamercolor{subsection in toc}{fg=mcmPip}%
  \setbeamercolor{bibliography entry author}{fg=mcmPip}%
  \setbeamercolor{bibliography entry cite}{fg=mcmPip}%
  \renewcommand{\mcmBulletColor}{mcmPip}%
  \hypersetup{urlcolor=mcmPrimary, linkcolor=mcmPrimary, citecolor=mcmPrimary}%
}

% ---------------------------------------------------------------------------
% GLOBAL COLOURS (theme-independent)
% ---------------------------------------------------------------------------
\setbeamercolor{normal text}{fg=mcmBlack, bg=mcmBg}
\setbeamercolor{structure}{fg=mcmDeepGreen}
\setbeamercolor{block body}{fg=mcmBlack, bg=mcmBg}
\setbeamercolor{bibliography entry title}{fg=mcmBlack}
\setbeamercolor{bibliography entry location}{fg=mcmBlack}
\setbeamercolor{bibliography entry note}{fg=mcmBlack}

% Bullet colour macro (must be defined before first \mcmTheme call)
\newcommand{\mcmBulletColor}{mcmPip}

% Apply default theme
\mcmTheme{DeepBlue}

% ---------------------------------------------------------------------------
% FONT ASSIGNMENTS
% ---------------------------------------------------------------------------
\setbeamerfont{title}{size={\fontsize{21}{23}}, series=\bfseries}
\setbeamerfont{subtitle}{size=\large, series=\mdseries}
\setbeamerfont{author}{size=\Large}
\setbeamerfont{institute}{size=\small}
\setbeamerfont{date}{size=\scriptsize}
\setbeamerfont{frametitle}{size=\large, series=\bfseries}
\setbeamerfont{block title}{size=\normalsize, series=\bfseries}
\setbeamerfont{section in toc}{size=\normalsize, series=\bfseries}
\setbeamerfont{subsection in toc}{size=\small}

% ---------------------------------------------------------------------------
% FRAME TITLE — coloured band with accent line below
%
% Left padding: \mcmFrameTitleLeft (default 0.35cm)
% ---------------------------------------------------------------------------
\newlength{\mcmFrameTitleLeft}
\setlength{\mcmFrameTitleLeft}{0.35cm}

\setbeamertemplate{frametitle}{%
  \nointerlineskip
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=1.10cm, dp=0.0cm,
      leftskip=\mcmFrameTitleLeft, rightskip=0.4cm]{frametitle}%
    \vbox to 1.10cm{%
      \vfil
      \usebeamerfont{frametitle}\mcmTitleFormat{\insertframetitle}%
      \ifx\insertframesubtitle\@empty\else
        \hspace{0.4em}{\small\color{mcmPrimaryAccent!70}\insertframesubtitle}%
      \fi
      \vfil
    }%
  \end{beamercolorbox}%
  \nointerlineskip
  \begin{tikzpicture}[remember picture, overlay]
    \fill[mcmPrimaryFg]
      ([yshift=-1.10cm]current page.north west)
      rectangle ([yshift=-1.10cm - 0.8pt]current page.north east);
  \end{tikzpicture}%
}

% ---------------------------------------------------------------------------
% BLOCKS — pip + title, single colorbox per block
%
% Internal padding: \mcmBlockPad (default 0.45em)
% Title indent: \mcmBlockTitleIndent (default 0.3em)
% ---------------------------------------------------------------------------
\newlength{\mcmBlockPad}
\setlength{\mcmBlockPad}{0.45em}

\newlength{\mcmBlockTitleIndent}
\setlength{\mcmBlockTitleIndent}{0.3em}

\setbeamertemplate{block begin}{%
  \par\vskip0.6ex%
  \begin{beamercolorbox}[%
      wd=\textwidth, colsep*=\mcmBlockPad,
      sep=0.5ex]{block body}%
    {\hspace{\mcmBlockTitleIndent}%
     \llap{\textcolor{mcmPip}{\rule{3pt}{1.75ex}}\hspace{0.45em}}%
     \usebeamerfont{block title}\usebeamercolor[fg]{block title}%
     \insertblocktitle\par}%
    \vskip0.4ex
    \usebeamerfont{block body}\usebeamercolor[fg]{block body}%
}
\setbeamertemplate{block end}{%
  \end{beamercolorbox}\vskip0.7ex%
}

\setbeamertemplate{block alerted begin}{%
  \par\vskip0.6ex%
  \begin{beamercolorbox}[%
      wd=\textwidth, colsep*=\mcmBlockPad,
      sep=0.5ex]{block body alerted}%
    {\hspace{\mcmBlockTitleIndent}%
     \llap{\textcolor{mcmAlert}{\rule{3pt}{1.75ex}}\hspace{0.45em}}%
     \usebeamerfont{block title}\usebeamercolor[fg]{block title alerted}%
     \insertblocktitle\par}%
    \vskip0.4ex
    \usebeamerfont{block body}\usebeamercolor[fg]{block body alerted}%
}
\setbeamertemplate{block alerted end}{%
  \end{beamercolorbox}\vskip0.7ex%
}

\setbeamertemplate{block example begin}{%
  \par\vskip0.6ex%
  \begin{beamercolorbox}[%
      wd=\textwidth, colsep*=\mcmBlockPad,
      sep=0.5ex]{block body example}%
    {\hspace{\mcmBlockTitleIndent}%
     \llap{\textcolor{mcmExample}{\rule{3pt}{1.75ex}}\hspace{0.45em}}%
     \usebeamerfont{block title}\usebeamercolor[fg]{block title example}%
     \insertblocktitle\par}%
    \vskip0.4ex
    \usebeamerfont{block body}\usebeamercolor[fg]{block body example}%
}
\setbeamertemplate{block example end}{%
  \end{beamercolorbox}\vskip0.7ex%
}

% ---------------------------------------------------------------------------
