\addtobeamertemplate{block alerted end}{\renewcommand{\mcmBulletColor}{mcmPip}}{}
\addtobeamertemplate{block example begin}{\renewcommand{\mcmBulletColor}{mcmExample}}{}
\addtobeamertemplate{block example end}{\renewcommand{\mcmBulletColor}{mcmPip}}{}

\setbeamertemplate{itemize item}{%
  \tikz[baseline=-0.8ex]{%
    \draw[\mcmBulletColor, line width=0.5pt] (0,0) circle(0.08);
    \fill[\mcmBulletColor] (0,0) circle(0.03);
  }%
}
\setbeamertemplate{itemize subitem}{%
  \tikz[baseline=-0.7ex]{%
    \draw[\mcmBulletColor, line width=0.5pt] (0,0.09) -- (0.09,0) -- (0,-0.09) -- (-0.09,0) -- cycle;
    \fill[\mcmBulletColor] (0,0) circle(0.025);
  }%
}
\setbeamertemplate{itemize subsubitem}{%
  \tikz[baseline=-0.7ex]{%
    \draw[\mcmBulletColor, line width=0.5pt] (-0.06,-0.06) rectangle (0.06,0.06);
    \fill[\mcmBulletColor] (0,0) circle(0.02);
  }%
}
\setbeamertemplate{enumerate item}{%
  \tikz[baseline=-0.725ex]{%
    \fill[\mcmBulletColor] (0,0) circle(0.12);
    \node[white, font=\tiny\bfseries] at (0,0) {\insertenumlabel};
  }%
}
\setbeamertemplate{enumerate subitem}{%
  \tikz[baseline=-0.65ex]{%
    \fill[\mcmBulletColor] (0,0) circle(0.105);
    \node[white, font=\tiny] at (0,0) {\insertsubenumlabel};
