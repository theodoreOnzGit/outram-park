% COLOUR PALETTE
% ---------------------------------------------------------------------------
\definecolor{mcmDeepGreen}{HTML}{09342A}
\definecolor{mcmGreen}{HTML}{177F6B}
\definecolor{mcmLightGreen}{HTML}{EEFAF4}
\definecolor{mcmBg}{HTML}{F8F6F2}
\definecolor{mcmMintBlock}{HTML}{EAF8F2}
\definecolor{mcmMintTitle}{HTML}{4DB896}
\definecolor{mcmLightGray}{HTML}{F5F5F5}
\definecolor{mcmBlack}{HTML}{1A1A1A}
\definecolor{mcmDeepBlue}{HTML}{002d4d}
\definecolor{mcmDarkBlue}{HTML}{1a2a3b}
\definecolor{mcmLightBlue}{HTML}{BFE5EE}
\definecolor{mcmTerracotta}{HTML}{9C4732}
\definecolor{mcmKraft}{HTML}{DEC5A6}
\definecolor{mcmKraftLight}{HTML}{E8D5B5}
\definecolor{mcmPink}{HTML}{E8637D}
\definecolor{mcmLightPink}{HTML}{FCEEF1}
