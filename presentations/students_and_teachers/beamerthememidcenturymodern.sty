% ---------------------------------------------------------------------------
% TABLE OF CONTENTS
% ---------------------------------------------------------------------------
\setbeamertemplate{section in toc}{%
  \hspace{0.1cm}%
  \raisebox{0.2ex}{\tikz{\fill[mcmPip](0,0) rectangle (0.14,0.14);}}%
  \hspace{0.25cm}%
  {\usebeamerfont{section in toc}\inserttocsection}\par%
}
\setbeamertemplate{subsection in toc}{%
  \hspace{0.65cm}%
  \raisebox{0.0ex}{\tikz{\fill[mcmPip] (0,0) circle(0.055);}}%
  \hspace{0.2cm}%
  {\usebeamerfont{subsection in toc}\inserttocsubsection}\par%
}

% ---------------------------------------------------------------------------
% FOOTLINE — progress bar, suppressed on the title page
% ---------------------------------------------------------------------------
\newif\if@mcmtitlepage
\@mcmtitlepagefalse

\addtobeamertemplate{frametitle}{\global\@mcmtitlepagefalse}{}
\BeforeBeginEnvironment{frame}{\global\@mcmtitlepagefalse}

\newcommand{\mcmFootlineContent}{%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[mcmPrimaryMuted]
      (current page.south west)
      rectangle ([yshift=0.06cm]current page.south east);
    \pgfmathsetmacro{\mcmprog}{\insertframenumber / \inserttotalframenumber}%
    \fill[mcmPrimary]
      (current page.south west)
      rectangle ([xshift=\mcmprog\paperwidth, yshift=0.06cm]current page.south west);
    \node[anchor=south west, inner sep=0pt]
      at ([xshift=0.4cm, yshift=0.10cm]current page.south west)
      {{\tiny\color{mcmBlack!45}\insertshortauthor}};
    \node[anchor=south, inner sep=0pt]
      at ([yshift=0.10cm]current page.south)
      {{\tiny\color{mcmBlack!45}\insertshorttitle}};
    \node[anchor=south east, inner sep=0pt]
      at ([xshift=-0.4cm, yshift=0.10cm]current page.south east)
      {{\tiny\color{mcmBlack!45}\textbf{\insertframenumber}\,/\,\inserttotalframenumber}};
  \end{tikzpicture}%
  \leavevmode\hbox to \paperwidth{\vbox to 0.45cm{}\hss}%
}

\setbeamertemplate{footline}{%
  \if@mcmtitlepage\else\mcmFootlineContent\fi%
}

% ---------------------------------------------------------------------------
% SECTION PAGE
% ---------------------------------------------------------------------------
\setbeamertemplate{section page}{%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[mcmBg]
      (current page.south west) rectangle (current page.north east);
    \fill[mcmPrimary]
      (current page.south west)
      rectangle ([xshift=0.45cm]current page.north west);
    \fill[mcmPrimary!45]
      ([xshift=0.45cm]current page.south west)
      rectangle ([xshift=0.60cm]current page.north west);
    \node[anchor=south west, inner sep=0pt,
          font=\small\bfseries, text=mcmPrimary!55]
      at ([xshift=1.1cm, yshift=0.18cm]current page.west)
      {\MakeUppercase{Section}\ \insertsectionnumber};
    \node[anchor=west, text width=0.80\paperwidth,
          align=left, inner sep=0pt]
      at ([xshift=1.1cm, yshift=-0.55cm]current page.west)
      {{\usebeamerfont{title}\color{mcmPrimary}\insertsection}};
  \end{tikzpicture}%
}

% ---------------------------------------------------------------------------
% SUBSECTION PAGE
% ---------------------------------------------------------------------------
\setbeamertemplate{subsection page}{%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[mcmBg]
      (current page.south west) rectangle (current page.north east);
    \fill[mcmPrimary]
      (current page.north west)
      rectangle ([yshift=-0.18cm]current page.north east);
    \node[anchor=north west, inner sep=0pt,
          font=\small, text=mcmPrimary!50]
      at ([xshift=1.1cm, yshift=-0.38cm]current page.north west)
      {\insertsection\ \textbf{/}};
    \node[anchor=west, text width=0.80\paperwidth,
          align=left, inner sep=0pt]
      at ([xshift=1.1cm, yshift=0.4cm]current page.west)
      {%
        {\small\color{mcmPrimary!60}\MakeUppercase{Section}\ %
         \insertsectionnumber.\insertsubsectionnumber}\\[0.3cm]
        {\usebeamerfont{frametitle}\color{mcmPrimary}\insertsubsection}%
      };
  \end{tikzpicture}%
}

% ---------------------------------------------------------------------------
% TITLE PAGE
%
% Footer height: \mcmFooterHeight (default 5em)
% Logo vertical offset: \mcmLogoVOffset (default 0cm, positive = up)
% Scan line spacing: \mcmLineSpacing (default 0.18cm)
%
% The logo is automatically positioned so that there is always 0.75cm of
% scan lines to its right. The gap width adapts to the logo size.
% Both gap edges use cosine-modulated rounding for an organic shape.
% ---------------------------------------------------------------------------
\newsavebox{\mcmTitleGraphicBox}
\newlength{\mcmLogoW}
\newlength{\mcmLogoH}
\newlength{\mcmFooterHeight}
\setlength{\mcmFooterHeight}{5em}
\newlength{\mcmLogoVOffset}
\setlength{\mcmLogoVOffset}{0cm}
\newif\if@mcmhaslogo

\newlength{\mcmLineSpacing}
\setlength{\mcmLineSpacing}{0.18cm}

\setbeamertemplate{title page}{%
  \global\@mcmtitlepagetrue
  \sbox{\mcmTitleGraphicBox}{\inserttitlegraphic}%
  \setlength{\mcmLogoW}{\wd\mcmTitleGraphicBox}%
  \setlength{\mcmLogoH}{\ht\mcmTitleGraphicBox}%
  \addtolength{\mcmLogoH}{\dp\mcmTitleGraphicBox}%
  \ifdim\mcmLogoW>0pt \@mcmhaslogotrue\else\@mcmhaslogofalse\fi
  %
  % Background and footer strip
  \begin{tikzpicture}[remember picture, overlay]
    \fill[mcmPrimary]
      (current page.south west) rectangle (current page.north east);
    \fill[mcmBg]
      (current page.south west)
      rectangle ([yshift=\mcmFooterHeight]current page.south east);
    \draw[line width=0.3pt, color=mcmPrimaryDark]
      ([yshift=\mcmFooterHeight]current page.south west) --
      ([yshift=\mcmFooterHeight]current page.south east);
  \end{tikzpicture}%
  %
  % Scan lines and logo, centred in the footer strip.
  % Right segments are always 0.75cm long (ending 0.3cm from the right edge).
  % The gap width adapts to the logo; the logo is centred within the gap.
  % Both gap edges use cosine-modulated rounding for an organic shape.
  \if@mcmhaslogo
    \begin{tikzpicture}[remember picture, overlay]
      \pgfmathsetlengthmacro{\rightfixed}{\paperwidth - 1.05cm}
      \pgfmathsetlengthmacro{\logocx}{\rightfixed - 0.5\mcmLogoW}
      % Place logo
      \node[anchor=center] (mcmlogo)
        at ([xshift=\logocx,
             yshift=0.5\mcmFooterHeight + \mcmLogoVOffset]current page.south west)
        {\usebox{\mcmTitleGraphicBox}};
      % Draw scan lines
      \foreach \i in {0,...,6}{%
        \pgfmathsetmacro{\imid}{3}%
        \pgfmathsetlengthmacro{\ysh}{%
          0.5\mcmFooterHeight + (\i - \imid) * \mcmLineSpacing}
        \pgfmathsetmacro{\thet}{(\i - \imid) * 3.14159 / 6}
        \pgfmathsetmacro{\cf}{abs(cos(\thet r))}
        \pgfmathsetlengthmacro{\xm}{0.25cm * (0.4 + 0.8 * \cf)}
        % Left segment
        \pgfmathsetlengthmacro{\leftend}{\logocx - 0.5\mcmLogoW - \xm}
        \draw[line width=0.5pt, color=mcmScanLine]
          ([xshift=0.3cm, yshift=\ysh]current page.south west)
            -- ([xshift=\leftend, yshift=\ysh]current page.south west);
        % Right segment
        \pgfmathsetlengthmacro{\rightstart}{\logocx + 0.5\mcmLogoW + \xm}
        \draw[line width=0.5pt, color=mcmScanLine]
          ([xshift=\rightstart, yshift=\ysh]current page.south west)
            -- ([xshift=-0.3cm, yshift=\ysh]current page.south east);
      }
    \end{tikzpicture}%
  \else
    \begin{tikzpicture}[remember picture, overlay]
      \foreach \i in {0,...,6}{%
        \pgfmathsetmacro{\imid}{3}%
        \pgfmathsetlengthmacro{\ysh}{%
          0.5\mcmFooterHeight + (\i - \imid) * \mcmLineSpacing}
        \draw[line width=0.5pt, color=mcmScanLine]
          ([xshift=0.3cm, yshift=\ysh]current page.south west)
            -- ([xshift=-0.3cm, yshift=\ysh]current page.south east);
      }
    \end{tikzpicture}%
  \fi
  
  % Title text
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=east, text width=0.9\paperwidth, align=flush right, inner sep=0pt]
      at ([xshift=-0.06\paperwidth, yshift=0.5\mcmFooterHeight]current page.east)
      {%
        \parbox[t]{0.9\paperwidth}{\raggedleft
         \spaceskip=\fontdimen2\font plus \fontdimen3\font minus \fontdimen4\font
         \advance\spaceskip by \mcmTitleWordSpacing
         \usebeamerfont{title}\color{mcmPrimaryFg}\mcmTitleFormat{\inserttitle}\par}%
        \ifx\insertsubtitle\@empty\else\par\vskip0.25cm%
          {\usebeamerfont{subtitle}\color{mcmPrimaryAccent!60!white}\insertsubtitle\par}%
        \fi\vskip0.50cm
        {\usebeamerfont{author}\color{mcmPrimaryFg}\insertauthor\par}\vskip0.08cm
        {\usebeamerfont{institute}\color{mcmPrimaryFg}\insertinstitute\par}%
      };
    \node[anchor=south east, inner sep=0pt]
      at ([xshift=-0.06\paperwidth, yshift=\mcmFooterHeight + 0.5cm]current page.south east)
      {{\usebeamerfont{date}\color{mcmPrimaryFg}\insertdate}};
  \end{tikzpicture}%
}

\endinput
